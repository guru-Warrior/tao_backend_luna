# Web UI gate (optional). Non-empty = password for /, /api/*, /ws. Leave empty to disable.
APP_ACCESS_PASSWORD=123123123

# CORS: comma-separated frontend origins when UI and API differ (e.g. https://your-app.vercel.app).
# Omit for localhost dev defaults. Do not use * if the browser must send cookies (credentials).
CORS_ORIGINS=https://your-frontend.example.com

# Bittensor Wallet Configuration (use real values only in a private .env — never commit .env)
WALLET_PASSWORD=
WALLET_NAME=harry
VALIDATOR_HOTKEY=

# Staking Configuration
CHECK_INTERVAL=2
ORIGINAL_STAKE_TAO=3
STAKE_AMOUNT_TAO=3
SUBNET_ID=18

# Network configuration (default: finney)
NETWORK=finney

# Monitoring configuration
MONITOR_INTERVAL=30

# Optional: override subnet list URL for pool liquidity (default: backprop GET /api/subnets, all subnets in one response)
# BACKPROP_SUBNETS_URL=https://backprop.finance/api/subnets

## Alpha token trading
STAKE_NETUID=7
STAKE_AMOUNT=0.1

UNSTAKE_NETUID=
UNSTAKE_AMOUNT=

# Seed phrases for direct-signing trades (optional)
SEED_PHRASE_1=
SEED_PHRASE_2=

# Default hotkey for trading (validator SS58)
TRADE_HOTKEY=5GKH9FPPnWSUoeeTJp19wVtd84XqFW4pyK2ijV2GsFbhTrP1

# btcli wallet/hotkey names (must exist in ~/.bittensor/wallets/)
BTCLI_WALLET=harry
BTCLI_HOTKEY=

# MEV Shield batch sell: 1 = wait for force_batch reveal (default, one tx for all positions);
# 0 = return after outer tx inclusion only.
# MEV_SHIELD_BATCH_WAIT_REVEAL=1

# --- Faker (decoy self-proxy extrinsic) ---
# Static knobs; per-submit values (netuid, dest_netuid, amount, real, action)
# come from the UI. Reuses WALLET_PASSWORD above for unattended coldkey unlock.
FAKE_WALLET=harry
FAKE_HOTKEY=5FUYrs2JNEW6cYjDC6F1mZYw4gLZG4mPLsZeAEe9cYVTrZzK
FAKE_ALPHA=
FAKE_REPEAT=1
FAKE_DELAY=11.8
FAKE_INTERVAL=0
