# Web UI gate (optional). Non-empty = password for /, /api/*, /ws. Leave empty to disable.
APP_ACCESS_PASSWORD=123123123

# CORS: comma-separated frontend origins when UI and API differ (e.g. https://your-app.vercel.app).
# Omit for localhost dev defaults. Do not use * if the browser must send cookies (credentials).
CORS_ORIGINS=https://your-frontend.example.com

# Bittensor Wallet Configuration (use real values only in a private .env — never commit .env)
WALLET_PASSWORD=
WALLET_NAME=harry
VALIDATOR_HOTKEY=

# Staking Configuration
CHECK_INTERVAL=2
ORIGINAL_STAKE_TAO=3
STAKE_AMOUNT_TAO=3
SUBNET_ID=18

# Network configuration (default: finney)
NETWORK=finney

# Substrate RPC endpoint for the mempool monitor / block processing / trader.
# Default is the public Finney entrypoint. A dedicated/paid node here removes the
# public endpoint's tail latency and is the single biggest lever for fast,
# reliable block transitions in the UI.
# SUBSTRATE_WS_URL=wss://entrypoint-finney.opentensor.ai:443

# --- Performance tuning (block transition speed / RPC load) ---
# Block processing runs on its own thread + WS connection so it never serializes
# behind mempool polling or snapshot building. These knobs control how often the
# remaining periodic RPCs fire; raise them to cut public-RPC load further (at the
# cost of slightly staler displayed values), lower them for fresher data.
#
# How often the full subnet price table is refreshed (two query_map calls, the
# heaviest single cost in block processing). Refreshed at most once per interval
# instead of every block. Seconds. Default 12 (~1 block).
# PRICE_REFRESH_SEC=12
#
# Per-address background refresh cadence for the displayed free TAO balance.
# Replaces per-block mass invalidation: a shown balance can lag reality by at
# most this many seconds but never blanks. Seconds. Default 60.
# BALANCE_REFRESH_SEC=60
#
# Mempool poll cadence: BUSY = pending stake txs present, IDLE = empty. Seconds.
# MEMPOOL_POLL_BUSY_SEC=0.2
# MEMPOOL_POLL_IDLE_SEC=0.5
#
# How often the chain head is polled as a fallback to the block subscription. Seconds.
# MEMPOOL_HEAD_POLL_SEC=0.4
#
# Max blocks processed in one catch-up pass when the monitor falls behind the tip.
# MEMPOOL_MAX_CATCHUP_BLOCKS=512
#
# Max age before a stuck pending extrinsic is force-hidden from the UI. Seconds.
# MEMPOOL_MAX_AGE_S=60

# Monitoring configuration
MONITOR_INTERVAL=30

# Optional: override subnet list URL for pool liquidity (default: backprop GET /api/subnets, all subnets in one response)
# BACKPROP_SUBNETS_URL=https://backprop.finance/api/subnets

## Alpha token trading
STAKE_NETUID=7
STAKE_AMOUNT=0.1

UNSTAKE_NETUID=
UNSTAKE_AMOUNT=

# Seed phrases for direct-signing trades (optional)
SEED_PHRASE_1=
SEED_PHRASE_2=

# Default hotkey for trading (validator SS58)
TRADE_HOTKEY=5GKH9FPPnWSUoeeTJp19wVtd84XqFW4pyK2ijV2GsFbhTrP1

# btcli wallet/hotkey names (must exist in ~/.bittensor/wallets/)
BTCLI_WALLET=harry
BTCLI_HOTKEY=

# MEV Shield batch sell: 1 = wait for force_batch reveal (default, one tx for all positions);
# 0 = return after outer tx inclusion only.
# MEV_SHIELD_BATCH_WAIT_REVEAL=1

# --- Faker (decoy self-proxy extrinsic) ---
# Static knobs; per-submit values (netuid, dest_netuid, amount, real, action)
# come from the UI. Reuses WALLET_PASSWORD above for unattended coldkey unlock.
FAKE_WALLET=harry
FAKE_HOTKEY=5FUYrs2JNEW6cYjDC6F1mZYw4gLZG4mPLsZeAEe9cYVTrZzK
FAKE_ALPHA=
FAKE_REPEAT=1
FAKE_DELAY=11.8
FAKE_INTERVAL=0
